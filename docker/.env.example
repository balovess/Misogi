# =============================================================================
# Misogi (禊) — Production Environment Variables Template
# =============================================================================
# Copy this file to the project root as .env and configure your values:
#   cp docker/.env.example .env
#
# SECURITY WARNING: Never commit .env to version control.
# All password/secret fields MUST be changed before production use.
# =============================================================================

# ---- General Settings --------------------------------------------------------
MISOGI_LOG_LEVEL=info
RUST_LOG=info

# ---- Misogi Sender ----------------------------------------------------------
SENDER_GRPC_PORT=50051
REST_API_PORT=8080

# ---- Misogi Receiver --------------------------------------------------------
RECEIVER_GRPC_PORT=50052

# ---- SMTP Gateway -----------------------------------------------------------
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
SMTP_HOSTNAME=mail-misogi.local
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=587
SMTP_MAX_MESSAGE_SIZE=52428800

# ---- PostgreSQL (Audit Database) --------------------------------------------
POSTGRES_PORT=5432
POSTGRES_DB=misogi_audit
POSTGRES_USER=misogi
POSTGRES_PASSWORD=change-me-in-production

# ---- Redis (Job Queue) -----------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=change-me-in-production

# ---- Database Connection Strings --------------------------------------------
DATABASE_URL=postgres://misogi:change-me-in-production@postgres:5432/misogi_audit
REDIS_URL=redis://:change-me-in-production@redis:6379

# ---- JWT Authentication -----------------------------------------------------
JWT_ISSUER=misogi-auth
JWT_AUDIENCE=misogi-api
# RSA keys are mounted from /app/config/keys/ in the container
# Generate with: misogi_auth::jwt::JwtAuthenticator::generate_keypair("./config/keys")

# ---- External Scanner (ClamAV Example) --------------------------------------
CLAMAV_ADDR=clamav:3310
CLAMAV_PORT=3310

# ---- Monitoring Stack (Prometheus + Grafana) ---------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# ---- LDAP / Active Directory (Optional) -------------------------------------
# LDAP_URLS=ldap://ad.example.com:389,ldap://ad-backup.example.com:389
# LDAP_BASE_DN=dc=example,dc=com
# LDAP_BIND_DN=CN=misogi-service,OU=ServiceAccounts,DC=example,DC=com
# LDAP_BIND_PASSWORD=change-me-in-production
# LDAP_USER_SEARCH_BASE=OU=Users,DC=example,DC=com

# ---- OIDC / OAuth2 (Optional) -----------------------------------------------
# OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=misogi-client
# OIDC_CLIENT_SECRET=change-me-in-production
# OIDC_REDIRECT_URI=https://misogi.example.com/auth/callback
