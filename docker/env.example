# =============================================================================
# Misogi (禊) — Docker Environment Configuration
# =============================================================================
# Copy this file to .env and modify values as needed:
#   cp docker/env.example .env
#
# All variables are optional. Default values are shown below.
# Variables without defaults use built-in application defaults.
# =============================================================================

# ---- General Settings --------------------------------------------------------

# Log verbosity: trace, debug, info, warn, error
MISOGI_LOG_LEVEL=info

# Rust tracing log level (overrides application log level if set)
RUST_LOG=info

# Audit log output format: json, syslog, cef, custom
MISOGI_LOG_FORMAT=json

# ---- Sender Service Settings -----------------------------------------------

# HTTP API bind address for sender (host port mapping in compose)
SENDER_PORT=3001

# Transfer driver type for sender: direct_tcp, storage_relay, external_command
MISOGI_SENDER_DRIVER_TYPE=direct_tcp

# ---- Receiver Service Settings ----------------------------------------------

# HTTP API bind address for receiver (host port mapping in compose)
RECEIVER_PORT=3002

# Tunnel port for receiver (host port mapping in compose)
TUNNEL_PORT=9000

# Transfer driver type for receiver: direct_tcp, storage_relay
MISOGI_RECEIVER_DRIVER_TYPE=direct_tcp

# ---- Network / Tunnel Settings ---------------------------------------------

# Remote tunnel server address (e.g., tunnel.example.com:9000)
# Leave empty to disable tunnel mode
MISOGI_TUNNEL_REMOTE_ADDR=

# Authentication token for tunnel registration
MISOGI_TUNNEL_AUTH_TOKEN=

# ---- Security Settings ------------------------------------------------------

# Enable PII (Personal Identifiable Information) scanning on uploads
# Accepted values: true, false, 1, 0, yes, no
MISOGI_PII_ENABLED=false

# Enable vendor isolation system (multi-tenant access control)
MISOGI_VENDOR_ISOLATION_ENABLED=false

# ---- Advanced Settings (uncomment to override) ------------------------------
# The following variables map directly to application configuration fields.
# Uncomment and set only when you need to override TOML file defaults.

# MISOGI_SERVER_ADDR=0.0.0.0:3001          # Override sender server bind address
# MISOGI_UPLOAD_DIR=/data/uploads           # Override sender upload directory
# MISOGI_STAGING_DIR=/data/staging         # Override sender staging directory
# MISOGI_CHUNK_DIR=/data/chunks            # Override receiver chunk storage dir
# MISOGI_DOWNLOAD_DIR=/data/downloads      # Override receiver download directory
# MISOGI_TRANSFER_DRIVER_TYPE=storage_relay # Global driver type override
